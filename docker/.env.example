# Variables de entorno para el despliegue con Docker
# Copia este archivo como .env en la carpeta docker/ y completa los valores

# ─── OBLIGATORIO ────────────────────────────────────────────────
# Clave secreta para firmar los JWT. Usa una cadena aleatoria larga.
# Ejemplo de generación: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=cambia_esto_por_una_clave_segura_minimo_32_caracteres
